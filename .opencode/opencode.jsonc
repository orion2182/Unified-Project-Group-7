{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "security-tools": {
      "type": "local",
      "command": ["python3", "/home/vedara/claude-skills/bug-bounty/scripts/mcp_security_server.py"],
      "enabled": true,
      "timeout": 900000
    },
    "metasploit": {
      "type": "local",
      "command": ["python3", "/home/vedara/Documents/Kelompok 7/scripts/mcp_metasploit.py"],
      "enabled": true,
      "timeout": 300000
    },
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem", "/home/vedara"],
      "enabled": true,
      "timeout": 60000
    }
  },
  "command": {
    "pentest": {
      "description": "Full gray box pentest — credentials → MITRE ATT&CK → CVSS v3.1 → UU PDP → MD + PDF report",
      "template": "Execute the complete gray box penetration test workflow. Read .opencode/commands/pentest.md for full instructions.",
      "agent": "general"
    },
    "set": {
      "description": "Set target for gray box testing",
      "template": "Set target URL and credentials. Format: /set <url> --token <jwt> --staff <username>",
      "agent": "general"
    },
    "audit": {
      "description": "Run security audit",
      "template": "Run audit for $ARGUMENTS. Use MCP security-tools for scanning.",
      "agent": "general"
    },
    "report": {
      "description": "Generate pentest report with UU PDP mapping",
      "template": "Generate report for $ARGUMENTS with legal mapping to UU PDP.",
      "agent": "general"
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    }
  },
  "agent": {
    "general": {
      "permission": {
        "skill": {
          "*": "allow"
        }
      },
      "tools": {
        "skill": true,
        "bash": true,
        "read": true,
        "write": true,
        "edit": true,
        "grep": true,
        "glob": true,
        "webfetch": true,
        "websearch": true
      }
    }
  },
  "skills": {
    "discovery": {
      "paths": [
        ".opencode/skills",
        ".claude/skills",
        ".agents/skills",
        "~/.config/opencode/skills",
        "~/.claude/skills",
        "~/.agents/skills"
      ]
    }
  }
}
